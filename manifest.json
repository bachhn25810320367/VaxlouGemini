{
  "manifest_version": 3,
  "name": "Vaxlou — Premium Gemini Powerhouse",
  "version": "2.39.0",
  "description": "Bookmark Bar, Rich Notes, Interactive Outline, AI Context Condenser, 8 Premium Themes, Overload Handler cho Gemini Web.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
